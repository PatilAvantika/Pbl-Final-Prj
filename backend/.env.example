DATABASE_URL="postgresql://user:pass@localhost:5432/ngo"
# Neon cold start / slow networks: ms to wait for a new TCP connection (default 90000).
# DATABASE_CONNECTION_TIMEOUT_MS=120000
# DATABASE_POOL_MAX=10
# Volunteer dashboard Redis cache TTL (seconds), 30–600. Default 90.
# VOLUNTEER_DASHBOARD_CACHE_TTL_SEC=90
JWT_SECRET="change-me-to-a-long-random-string"
# Access token (httpOnly cookie) — default 900 (15 min) if unset
JWT_ACCESS_EXPIRES_SEC=900
# Refresh token (httpOnly cookie) — default 604800 (7 days) if unset
JWT_REFRESH_EXPIRES_SEC=604800
PORT=3000
# Comma-separated origins, e.g. http://localhost:3001 — required in production for credentialed cookies
CORS_ORIGIN=http://localhost:3001
NODE_ENV=development
# API routes are served under /api/v1 (health + ready stay at /health, /ready).
# Frontend: NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# Optional: Redis for donor dashboard cache (GET /donor/dashboard), TTL ~120s. Omit to disable.
# REDIS_URL=redis://localhost:6379
# Optional: BullMQ report-processing queue (also requires REDIS_URL)
# BULLMQ_ENABLED=true
# Optional: force cookie flags (else secure=true only when NODE_ENV=production)
# COOKIE_SECURE=false
# COOKIE_SAME_SITE=lax

# --- Optional AI (never blocks core CRUD if unset or failing) ---
# OpenAI: generative chat (POST /api/v1/chatbot/ai) + field report ai_summary after submit
# OPENAI_API_KEY=        # set only in hosting secrets / local .env — never commit
# OPENAI_MODEL=gpt-4o-mini
# Python FastAPI ranking (see repo ai-service/). If unset or down, Nest uses rule-based fallback.
# AI_SERVICE_URL=http://localhost:8000
